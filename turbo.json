{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "validate-content": {
      "dependsOn": ["^build"]
    },
    "generate-search": {
      "dependsOn": ["^build"],
      "outputs": ["public/search-index.json"]
    },
    "audit:copy": {},
    "audit:links": {},
    "audit:tags": {}
  }
}
